###############################################
# Docker Compose environment for the web app  #
###############################################

# Build with Bake
COMPOSE_BAKE=true
CONTAINER_PREFIX=XXX_APP_DOMAIN_XXX
IMAGE_NAME=XXX_APP_DOMAIN_XXX-django
IMAGE_TAG=latest

# Database (service: db)
POSTGRES_USER=XXX_PG_USER_XXX
POSTGRES_PASSWORD=XXX_PG_PASS_XXX
POSTGRES_DB=XXX_PG_DB_XXX
DATABASE_URL=postgres://XXX_PG_USER_XXX:XXX_PG_PASS_XXX@db:5432/XXX_PG_DB_XXX
# Persistent connections (seconds). 0 = open/close per request; higher avoids the
# Postgres connect handshake on every request behind Daphne / gunicorn / etc.
# Ignored when DJANGO_DB_POOL=True - the pool manages connection lifetime.
DJANGO_CONN_MAX_AGE=60
# Detect and replace stale persistent connections.
DJANGO_CONN_HEALTH_CHECKS=True
# Use Django's native psycopg3 connection pool. Postgres-only.
DJANGO_DB_POOL=True

# Cache-busted static asset URLs via a hashed manifest. Far-future Cache-Control headers
# at the nginx layer stay safe across deploys.
DJANGO_STATICFILES_STORAGE=django.contrib.staticfiles.storage.ManifestStaticFilesStorage

# General
DJANGO_SETTINGS_MODULE=event_talks.settings
DJANGO_READ_VARS_FILE=false
SITE_ID=1
DJANGO_DEBUG=false

# Internationalization
LANGUAGE_CODE=en-us
TIME_ZONE=Europe/Berlin
USE_I18N=true
USE_TZ=true

# Security
DJANGO_ALLOWED_HOSTS="talks.example.com,127.0.0.1"
DJANGO_CSRF_TRUSTED_ORIGINS="https://talks.example.com,http://127.0.0.1,http://localhost"
DJANGO_SECRET_KEY=XXX_DJ_SECRET_XXX
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
DATA_UPLOAD_MAX_NUMBER_FIELDS=3000

# Admin
ADMIN_NAMES="XXX_ADMIN_NAMES_XXX"
ADMIN_EMAILS="XXX_ADMIN_EMAILS_XXX"
DJANGO_ADMIN_URL=admin/

# Authentication / Allauth
ACCOUNT_LOGIN_BY_CODE_TIMEOUT=300
ACCOUNT_EMAIL_SUBJECT_PREFIX="[XXX_EVENT_NAME_XXX XXX_YEAR_XXX] "

# Email validation API
EMAIL_VALIDATION_API_URL_FALLBACK=
EMAIL_VALIDATION_API_TIMEOUT=10
AUTHORIZED_EMAILS_WHITELIST=

# OAuth2 client credentials for the validation API
# All three are required to enable OAuth2 authentication on validation API calls.
EMAIL_VALIDATION_API_OAUTH2_CLIENT_ID=
EMAIL_VALIDATION_API_OAUTH2_CLIENT_SECRET=
EMAIL_VALIDATION_API_OAUTH2_TOKEN_URL=

# Discord
DISCORD_CLIENT_ID=XXXXXXXXXXXXXXXXXXX
DISCORD_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
DISCORD_API_TIMEOUT=5
DISCORD_GUILD_ID=XXXXXXXXXXXXXXXXXX
DISCORD_ROLES='{"everyone":"AAAAA";"attendee":"BBBBB";"organiser":"CCCCC";"session_chair":"DDDDD";"volunteer":"EEEEE"}'
DISCORD_ALLOWED_ROLES=attendee,organiser,session_chair,volunteer
DISCORD_ADMIN_ROLES=organiser
DISCORD_STAFF_ROLES=session_chair

# Static and media files
DJANGO_STATIC_ROOT=/staticfiles
DJANGO_STATIC_URL=static/
# Static dirs are used only during collectstatic
DJANGO_STATICFILES_DIRS=
DJANGO_MEDIA_ROOT=/var/opt/XXX_APP_DOMAIN_XXX/media/
DJANGO_MEDIA_URL=/media/
MOUNT_MEDIA_ROOT=/var/opt/XXX_APP_DOMAIN_XXX/media/

# Email settings
DJANGO_EMAIL_BACKEND=anymail.backends.mailgun.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=Talks <talks@example.de>
SERVER_EMAIL=root@localhost
MAILGUN_API_KEY=XXX_MG_API_KEY_XXX
MAILGUN_API_URL=https://api.eu.mailgun.net/v3
MAILGUN_SENDER_DOMAIN=XXX_MG_DOMAIN_XXX

# Branding / Event configuration
DEFAULT_EVENT=XXX_EVENT_SLUG_XXX

# Pretalx
PRETALX_API_TOKEN=XXX_PRETALX_API_TOKEN_XXX
PICKLE_PRETALX_TALKS=False
# Recipients of the post-detect summary email (see docs/pretalx-sync.md). Empty value =
# fall back to ADMIN_EMAILS. Set to "-" to disable the digest entirely.
PRETALX_DIGEST_RECIPIENTS=

# Fonts
TALK_CARD_FONT="/usr/share/fonts/truetype/noto/NotoSans.ttf"

# Livestreams
LIVESTREAMS_SHEET_ID=XXX_LS_SHEET_ID_XXX
LIVESTREAMS_WORKSHEET_NAME=XXX_LS_WORKSHEET_NAME_XXX

# Vimeo
VIMEO_ACCESS_TOKEN=XXX_VIMEO_AT_XXX
VIMEO_PROJECT_IDS=XXXX,YYYY

# Feature flags
SHOW_UPCOMING_TALKS_LINKS=False
IMPORT_TALKS_WITHOUT_SPEAKERS=True

# Logging
LOG_EMAIL_HASH=False
DJANGO_LOGS_DIR=/logs/
MOUNT_LOGS_DIR=/var/log/XXX_APP_DOMAIN_XXX/
DJANGO_DATABASE_LOG_LEVEL=ERROR
LOG_LEVEL=INFO

# Sentry alerting (https://docs.sentry.io/platforms/python/integrations/django/)
# Leave SENTRY_DSN blank to disable.
SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.0
# SENTRY_SEND_DEFAULT_PII=False
