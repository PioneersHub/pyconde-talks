#################################
# Local development environment #
#################################

# General
# DJANGO_READ_VARS_FILE=True
DJANGO_DEBUG=True
SITE_ID=1

# Internationalization
LANGUAGE_CODE=en-us
TIME_ZONE=Europe/Berlin
USE_I18N=True
USE_TZ=True

# Database
DATABASE_URL=sqlite:///db.sqlite3
# Persistent connections (seconds). 0 = open/close per request; set higher in prod for
# Postgres so each request skips the connect handshake. 60 is a safe default.
# Ignored when DJANGO_DB_POOL=True - the pool manages connection lifetime.
DJANGO_CONN_MAX_AGE=60
# Detect and replace stale persistent connections (idle timeout, DB restart, proxy reset).
DJANGO_CONN_HEALTH_CHECKS=True
# Postgres-only: use Django's native connection pool (psycopg3). Recommended for prod;
# leave False on SQLite. When True, ``DJANGO_CONN_MAX_AGE`` is ignored.
DJANGO_DB_POOL=False

# Storage backends. In prod set DJANGO_STATICFILES_STORAGE to
# "django.contrib.staticfiles.storage.ManifestStaticFilesStorage" so collected static
# files get a content-hashed name and nginx can cache them forever. The default
# is the simple filesystem storage so dev / tests work without ``collectstatic``.
# DJANGO_STATICFILES_STORAGE=django.contrib.staticfiles.storage.StaticFilesStorage
# DJANGO_DEFAULT_FILE_STORAGE=django.core.files.storage.FileSystemStorage

# Security
DJANGO_SECRET_KEY=django-insecure-_)bw6fz9@qqh9379b6rsa=gcwv*v0uk-s^x3ov-kr-%du&=5+v
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,videos.pydata-berlin.org
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
DATA_UPLOAD_MAX_NUMBER_FIELDS=3000

# Admin
DJANGO_ADMIN_URL=admin/
ADMIN_NAMES=Julio B. Silva
ADMIN_EMAILS=julio@example.com

# Authentication
LOGIN_REDIRECT_URL=home
ACCOUNT_LOGIN_BY_CODE_TIMEOUT=300
ACCOUNT_LOGIN_BY_CODE_MAX_ATTEMPTS=3
ACCOUNT_EMAIL_SUBJECT_PREFIX="[PyData Berlin 2025] "

# Email validation API
EMAIL_VALIDATION_API_URL_FALLBACK=
EMAIL_VALIDATION_API_TIMEOUT=10
AUTHORIZED_EMAILS_WHITELIST=whitelisted@example.com

# OAuth2 client credentials for the validation API
# All three are required to enable OAuth2 authentication on validation API calls.
EMAIL_VALIDATION_API_OAUTH2_CLIENT_ID=
EMAIL_VALIDATION_API_OAUTH2_CLIENT_SECRET=
EMAIL_VALIDATION_API_OAUTH2_TOKEN_URL=

# Static and media files
# DJANGO_STATIC_ROOT=staticfiles
# DJANGO_STATICFILES_DIRS=
DJANGO_STATIC_URL=static/
DJANGO_MEDIA_ROOT=media
DJANGO_MEDIA_URL=/media/

# Email settings
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=1025
# EMAIL_TIMEOUT=10
# DEFAULT_FROM_EMAIL=webmaster@localhost
# SERVER_EMAIL=root@localhost
# MAILGUN_API_KEY=
# MAILGUN_API_URL=https://api.eu.mailgun.net/v3
# MAILGUN_SENDER_DOMAIN=

# Event info
DEFAULT_EVENT=pyconde-pydata-2026

# Pretalx
PRETALX_API_TOKEN=
PICKLE_PRETALX_TALKS=True

# Fonts
# TALK_CARD_FONT=

# Google Sheets streams
LIVESTREAMS_SHEET_ID=
LIVESTREAMS_WORKSHEET_NAME=

# Vimeo
VIMEO_ACCESS_TOKEN=
VIMEO_PROJECT_IDS=

# Feature flags
SHOW_UPCOMING_TALKS_LINKS=True
IMPORT_TALKS_WITHOUT_SPEAKERS=True

# Logging
DJANGO_LOGS_DIR=logs
DJANGO_DATABASE_LOG_LEVEL=ERROR
LOG_LEVEL=INFO

# Sentry (alerting / error tracking)
# Leave SENTRY_DSN blank in dev to disable. In prod set the DSN from your Sentry project.
# https://docs.sentry.io/platforms/python/integrations/django/
SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.0
# SENTRY_SEND_DEFAULT_PII=False

# Discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_API_TIMEOUT=5
DISCORD_GUILD_ID=
DISCORD_ROLES='{"everyone":"AAAAA","attendee":"BBBBB","organiser":"CCCCC","session_chair":"DDDDD","volunteer":"EEEEE"}'
DISCORD_ALLOWED_ROLES=attendee,organiser,session_chair,volunteer
DISCORD_ADMIN_ROLES=organiser
DISCORD_STAFF_ROLES=session_chair
